spring.application.name=techdepot

# =============================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================
# Elige UNA de las siguientes opciones según tu instalación de SQL Server:

# OPCIÓN A: Instancia nombrada (por defecto en SQL Server Express)
# No requiere configurar TCP/IP. Usa el servicio SQL Server Browser.
spring.datasource.url=jdbc:sqlserver://localhost;instanceName=SQLEXPRESS;databaseName=TechDepot;encrypt=true;trustServerCertificate=true;

# OPCIÓN B: Puerto TCP/IP directo (instancia por defecto o con TCP/IP configurado)
# spring.datasource.url=jdbc:sqlserver://localhost:1433;databaseName=TechDepot;encrypt=true;trustServerCertificate=true;

spring.datasource.username= YOUR_USER
spring.datasource.password= YOUR_PASSWORD
spring.datasource.driverClassName=com.microsoft.sqlserver.jdbc.SQLServerDriver

spring.jpa.show-sql=true
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.SQLServerDialect